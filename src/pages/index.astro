---
import Layout from '../layouts/Layout.astro';
---
<Layout>

  <!-- NAV -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 py-5 px-8">
    <div class="max-w-6xl mx-auto flex items-center justify-between">
      <a href="#" class="flex items-center" aria-label="Arseniy Goldberg">
        <svg width="68" height="30" viewBox="0 0 68 30" fill="none" xmlns="http://www.w3.org/2000/svg">
          <text x="1" y="24" style="font-family: var(--font-display); font-weight: 700; font-size: 25px; fill: white; letter-spacing: 4px;">AG</text>
          <text x="53" y="24" style="font-family: var(--font-display); font-weight: 700; font-size: 25px; fill: #F4621F;">.</text>
        </svg>
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="#work"        class="text-white/60 hover:text-white text-sm font-medium transition-colors" style="font-family: var(--font-display)">Work</a>
        <a href="#clients"     class="text-white/60 hover:text-white text-sm font-medium transition-colors" style="font-family: var(--font-display)">Clients</a>
        <a href="#brands"      class="text-white/60 hover:text-white text-sm font-medium transition-colors" style="font-family: var(--font-display)">Brands</a>
        <a href="#recognition" class="text-white/60 hover:text-white text-sm font-medium transition-colors" style="font-family: var(--font-display)">Recognition</a>
        <a href="#linkedin"    class="text-white/60 hover:text-white text-sm font-medium transition-colors" style="font-family: var(--font-display)">Writing</a>
        <a href="#contact" class="bg-orange-500 hover:bg-orange-600 text-white text-sm font-semibold px-5 py-2.5 rounded-full transition-colors" style="font-family: var(--font-display)">
          Let's Talk
        </a>
      </div>
      <button id="mobile-menu-btn" class="md:hidden text-white/60 hover:text-white">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 right-0 bg-navy-950/95 backdrop-blur-lg border-t border-white/10 px-8 py-6 flex flex-col gap-5">
      <a href="#work"        class="text-white/70 hover:text-white text-sm font-medium transition-colors" style="font-family: var(--font-display)">Work</a>
      <a href="#clients"     class="text-white/70 hover:text-white text-sm font-medium transition-colors" style="font-family: var(--font-display)">Clients</a>
      <a href="#brands"      class="text-white/70 hover:text-white text-sm font-medium transition-colors" style="font-family: var(--font-display)">Brands</a>
      <a href="#recognition" class="text-white/70 hover:text-white text-sm font-medium transition-colors" style="font-family: var(--font-display)">Recognition</a>
      <a href="#contact" class="bg-orange-500 text-white text-sm font-semibold px-5 py-3 rounded-full text-center transition-colors" style="font-family: var(--font-display)">Let's Talk</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero-bg min-h-screen flex items-center overflow-hidden">
    <div class="absolute left-[8%] top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-orange-500/15 to-transparent hidden lg:block"></div>
    <div class="relative z-10 w-full max-w-6xl mx-auto px-8 pt-28 pb-24 grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <h1 class="text-white leading-[1.0] mb-7" style="font-family: var(--font-display)">
          <span class="block font-bold tracking-tight" style="font-size: clamp(2.8rem,6vw,4.5rem)">12 Years.</span>
          <span class="block font-bold tracking-tight" style="font-size: clamp(2.8rem,6vw,4.5rem)">5 Continents.</span>
          <span class="block font-light mt-3" style="font-size: clamp(1.8rem,4vw,2.8rem); color: rgba(255,255,255,0.75)">One Obsession.</span>
        </h1>
        <p class="text-base leading-relaxed max-w-[400px] mb-5 font-medium" style="color: rgba(255,255,255,0.85)">
          How humans grow — through <span style="color:#F4621F;font-weight:700">Finance</span>,<br>
          <span style="color:#F4621F;font-weight:700">Artificial Intelligence</span>, and
          <span style="color:#F4621F;font-weight:700">Education</span>.
        </p>
        <p class="text-sm mb-10 tracking-widest uppercase font-semibold" style="font-family: var(--font-display); color: rgba(255,255,255,0.75)">
          I study it &nbsp;·&nbsp; I teach it &nbsp;·&nbsp; I build with it
        </p>
        <div class="flex flex-wrap gap-3 mb-5">
          <a href="#contact" class="bg-orange-500 hover:bg-orange-600 text-white font-semibold px-8 py-4 rounded-full transition-colors text-sm tracking-wide" style="font-family: var(--font-display)">
            Let's Work Together
          </a>
          <a href="#work" class="text-sm px-8 py-4 rounded-full transition-colors font-semibold" style="font-family: var(--font-display); border: 1px solid rgba(255,255,255,0.35); color: rgba(255,255,255,0.85)">
            Explore Work ↓
          </a>
        </div>
        <button onclick="openIntroVideo()" class="flex items-center gap-3 text-sm font-medium" style="font-family: var(--font-display); color: rgba(255,255,255,0.75); background:none; border:none; cursor:pointer; padding:0">
          <span style="width:36px;height:36px;background:rgba(244,98,31,0.2);border:1px solid rgba(244,98,31,0.5);border-radius:50%;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="#F4621F"><path d="M8 5v14l11-7z"/></svg>
          </span>
          Watch a 55-second intro
        </button>
      </div>
      <div class="relative hidden lg:flex justify-end">
        <div class="relative rounded-2xl overflow-hidden" style="width: 380px; aspect-ratio: 3/4; background: #162236">
          <img src="/hero.jpg" alt="Arseniy Goldberg" class="w-full h-full object-cover object-center" />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(13,27,42,0.5) 0%, transparent 60%)"></div>
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-28 pointer-events-none" style="background: linear-gradient(to top, #FAFAF8, transparent)"></div>
  </section>

  <!-- STATS BAR -->
  <section class="bg-warm-50 py-16 border-b border-warm-200">
    <div class="max-w-5xl mx-auto px-8">
      <div class="flex flex-wrap justify-center divide-x divide-warm-200">
        <div class="stat-item flex-1 min-w-[140px] text-center px-8 py-4 reveal">
          <p class="font-bold text-[2.5rem] text-navy-900 leading-none" style="font-family: var(--font-display)"><span class="counter" data-target="25">0</span><span class="text-orange-500">+</span></p>
          <p class="text-navy-400 text-sm mt-2" style="font-family: var(--font-display)">Independent Projects</p>
        </div>
        <div class="stat-item flex-1 min-w-[140px] text-center px-8 py-4 reveal reveal-delay-1">
          <p class="font-bold text-[2.5rem] text-navy-900 leading-none" style="font-family: var(--font-display)"><span class="counter" data-target="4">0</span></p>
          <p class="text-navy-400 text-sm mt-2" style="font-family: var(--font-display)">Innovation Programs Launched</p>
        </div>
        <div class="stat-item flex-1 min-w-[140px] text-center px-8 py-4 reveal reveal-delay-2">
          <p class="font-bold text-[2.5rem] text-navy-900 leading-none" style="font-family: var(--font-display)">5<span class="text-orange-500" style="font-size:1.5rem">th</span></p>
          <p class="text-navy-400 text-sm mt-2" style="font-family: var(--font-display)">Venture in Progress</p>
        </div>
        <div class="stat-item flex-1 min-w-[140px] text-center px-8 py-4 reveal reveal-delay-3">
          <p class="font-bold text-[2.5rem] text-navy-900 leading-none" style="font-family: var(--font-display)"><span class="counter" data-target="5">0</span></p>
          <p class="text-navy-400 text-sm mt-2" style="font-family: var(--font-display)">Teaching Excellence Awards</p>
        </div>
        <div class="stat-item flex-1 min-w-[140px] text-center px-8 py-4 reveal reveal-delay-4">
          <p class="font-bold text-[2.5rem] text-navy-900 leading-none" style="font-family: var(--font-display)"><span class="counter" data-target="35">0</span><span class="text-orange-500">+</span></p>
          <p class="text-navy-400 text-sm mt-2" style="font-family: var(--font-display)">Institutions Reached</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CREDIBILITY STRIP -->
  <section class="py-10 bg-warm-100 border-y border-warm-200">
    <div class="max-w-4xl mx-auto px-8 reveal">
      <p class="text-center text-navy-500 text-base leading-relaxed italic" style="font-size: clamp(1rem, 1.8vw, 1.2rem)">
        "Professor Arseniy was one of the most memorable speakers I've ever met — his knowledge, experience, and ability to communicate with compassion and conviction left a lasting impression."
      </p>
      <p class="text-center text-sm mt-4 font-semibold text-navy-400" style="font-family: var(--font-display)">Agil Zakariya &nbsp;·&nbsp; Brand Management, Procter & Gamble</p>
    </div>
  </section>

  <!-- WORK -->
  <section id="work" class="py-24 bg-warm-100">
    <div class="max-w-6xl mx-auto px-8">

      <!-- Manifesto heading -->
      <div class="mb-12 reveal">
        <h2 class="font-bold text-navy-900 leading-none mb-2" style="font-family: var(--font-display); font-size: clamp(2.8rem,5.5vw,4.5rem)">
          Finance. Startups. AI.
        </h2>
        <p class="font-light text-navy-400 mb-5" style="font-family: var(--font-display); font-size: clamp(1.2rem,2.5vw,1.75rem)">
          Built, advised, and taught — all three, at the same time.
        </p>
        <p class="text-navy-400 text-base max-w-2xl leading-relaxed">
          12 years working at the intersection of all three. Each discipline makes the others more honest.
        </p>
      </div>

      <!-- Three-strip manifesto -->
      <div class="rounded-2xl overflow-hidden mb-16 reveal">
        {[
          {
            num: "01",
            mode: "BUILD",
            tagline: "Ventures built from scratch — in Azerbaijan, Spain, and the US.",
            chips: ["SABAH Hub", "Flow Strategy", "North", "Stride"],
            stats: ["4 Innovation Programs", "Finance · EdTech · AI", "Azerbaijan · Spain · US"],
          },
          {
            num: "02",
            mode: "ADVISE",
            tagline: "Strategy to implementation. Built around real company challenges.",
            chips: ["Kyowa Kirin", "IE Law School", "TEC de Monterrey", "Royal Commission for AlUla"],
            stats: ["AI Implementation", "Digital Strategy", "Financial Modeling · GTM"],
          },
          {
            num: "03",
            mode: "TEACH",
            tagline: "Classrooms, boardrooms, briefing rooms. The standard doesn't change.",
            chips: ["STC", "PIF Saudi Arabia", "Qatari Police", "IE Business School", "Oregon State", "Leonardo"],
            stats: ["4.9 / 5 Rating", "NPS 70", "5× Teaching Excellence"],
          },
        ].map((s, i) => (
          <div
            class="relative overflow-hidden"
            style={`background:${i === 1 ? '#0f2236' : '#0D1B2A'};${i > 0 ? 'border-top:1px solid rgba(255,255,255,0.05)' : ''}`}
          >
            <span style="position:absolute;right:-0.5rem;top:50%;transform:translateY(-50%);font-size:9rem;font-weight:900;font-family:var(--font-display);color:rgba(255,255,255,0.025);line-height:1;pointer-events:none;user-select:none;letter-spacing:-0.05em">{s.num}</span>

            <div class="flex flex-col md:flex-row md:items-center gap-6 md:gap-10 px-8 md:px-12 py-10 relative z-10">
              <div class="flex-shrink-0 md:w-72">
                <p class="font-bold tracking-tight leading-none mb-2" style="font-family:var(--font-display);font-size:clamp(2rem,3.5vw,3rem);color:#fff">{s.mode}</p>
                <p class="text-sm leading-snug" style="color:rgba(255,255,255,0.4);max-width:240px">{s.tagline}</p>
              </div>

              <div class="hidden md:block flex-shrink-0" style="width:1px;height:56px;background:linear-gradient(to bottom,transparent,rgba(244,98,31,0.5),transparent)"></div>

              <div class="flex-1">
                <div class="flex flex-wrap gap-2 mb-4">
                  {s.chips.map(c => (
                    <span class="text-xs px-3 py-1 rounded-full" style="background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.65);border:1px solid rgba(255,255,255,0.1);font-family:var(--font-display);white-space:nowrap">{c}</span>
                  ))}
                </div>
                <div class="flex flex-wrap gap-x-5 gap-y-1">
                  {s.stats.map(st => (
                    <span class="text-xs font-bold" style="color:#F4621F;font-family:var(--font-display)">{st}</span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Outcomes label -->
      <div class="mb-8 reveal">
        <div class="section-label">
          <span class="text-orange-500 text-xs font-semibold tracking-[0.2em] uppercase" style="font-family: var(--font-display)">Work & Outcomes</span>
        </div>
        <p class="text-navy-400 text-sm">Programs built, tools deployed, and results delivered — across finance, AI, entrepreneurship, and human behavior.</p>
      </div>

      <!-- Tab bar -->
      <div class="border-b border-warm-200 mb-10 reveal flex justify-between" id="work-tabs">
        <button class="tab-btn active" data-tab="finance"          onclick="switchTab('finance')">Finance</button>
        <button class="tab-btn"        data-tab="entrepreneurship" onclick="switchTab('entrepreneurship')">Startups</button>
        <button class="tab-btn"        data-tab="innovation"       onclick="switchTab('innovation')">Innovation Programs</button>
        <button class="tab-btn"        data-tab="ai"               onclick="switchTab('ai')">AI Productivity</button>
        <button class="tab-btn"        data-tab="courses"          onclick="switchTab('courses')">Digital Courses</button>
        <button class="tab-btn"        data-tab="behavioral"       onclick="switchTab('behavioral')">Human Behavior</button>
      </div>

      <!-- FINANCE TAB -->
      <div id="tab-finance" class="tab-panel">
        <div class="grid md:grid-cols-3 gap-5">
          <div class="md:col-span-2 work-card work-card-featured bg-white rounded-2xl overflow-hidden">
            <div class="h-40 bg-navy-900 relative flex items-end p-6">
              <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(244,98,31,0.12) 0%, transparent 60%)"></div>
              <span class="relative z-10 bg-orange-500 text-white text-xs font-semibold px-3 py-1.5 rounded-full" style="font-family: var(--font-display)">25 Sessions</span>
            </div>
            <div class="p-7">
              <h3 class="font-bold text-xl text-navy-900 mb-1" style="font-family: var(--font-display)">Capital Markets</h3>
              <p class="text-navy-400 text-sm mb-3">How institutional money moves through global systems — and how to raise, deploy, and protect it.</p>
              <ul class="space-y-1.5">
                <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>Equity & debt market structure</li>
                <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>Institutional investors & capital raising</li>
                <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>IPOs, bonds, and alternative financing</li>
                <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>Valuation methods & market dynamics</li>
              </ul>
              <div class="mt-5 pt-5 border-t border-warm-100">
                <p class="text-xs font-semibold uppercase tracking-widest text-navy-300 mb-3" style="font-family:var(--font-display)">Valuation Tutors</p>
                <div class="flex flex-wrap gap-2">
                  {[
                    { name: "DCF Valuation", href: "https://claude.ai/public/artifacts/98996521-1957-4911-b45a-b67fe336f5d0" },
                    { name: "PVGO Model", href: "https://claude.ai/public/artifacts/fbfb82ab-e4cf-4cd4-b843-82b5775112a2" },
                    { name: "Dividend Discount", href: "https://claude.ai/public/artifacts/38df1612-3558-4f98-a4e3-8e40fce514fa" },
                    { name: "Book Value", href: "https://claude.ai/public/artifacts/2cceef54-0d52-4ae2-a4bb-33f0638739b8" },
                  ].map(t => (
                    <a href={t.href} target="_blank" rel="noopener"
                      class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-full transition-colors"
                      style="background:#FFF3EE;color:#F4621F;border:1px solid rgba(244,98,31,0.2);font-family:var(--font-display)">
                      <svg width="9" height="9" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                      {t.name}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          </div>
          <div class="flex flex-col gap-5">
            <div class="work-card bg-white rounded-2xl p-6 flex-1">
              <p class="text-xs text-navy-400 mb-2" style="font-family: var(--font-display)">15 Sessions</p>
              <h3 class="font-semibold text-base text-navy-900 mb-3" style="font-family: var(--font-display)">Corporate Finance</h3>
              <ul class="space-y-1.5">
                <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>Capital structure & WACC</li>
                <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>Investment decisions & NPV</li>
                <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>Financial strategy & planning</li>
              </ul>
            </div>
            <div class="work-card bg-white rounded-2xl p-6 flex-1">
              <p class="text-xs text-navy-400 mb-2" style="font-family: var(--font-display)">15 Sessions</p>
              <h3 class="font-semibold text-base text-navy-900 mb-3" style="font-family: var(--font-display)">Financial Consulting</h3>
              <ul class="space-y-1.5">
                <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>Advisory skills & client management</li>
                <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>Strategic financial solutions</li>
                <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>CFO-as-a-service frameworks</li>
              </ul>
            </div>
          </div>
          <div class="work-card bg-white rounded-2xl p-6">
            <p class="text-xs text-navy-400 mb-2" style="font-family: var(--font-display)">15 Sessions</p>
            <h3 class="font-semibold text-base text-navy-900 mb-3" style="font-family: var(--font-display)">AI-Powered Finance</h3>
            <ul class="space-y-1.5">
              <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>GenAI for financial analysis & modeling</li>
              <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>AI use cases across the finance function</li>
            </ul>
          </div>
          <div class="work-card bg-white rounded-2xl p-6">
            <p class="text-xs text-navy-400 mb-2" style="font-family: var(--font-display)">15 Sessions</p>
            <h3 class="font-semibold text-base text-navy-900 mb-3" style="font-family: var(--font-display)">Financial Markets & Fintech</h3>
            <ul class="space-y-1.5">
              <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>Market structure, instruments & trading</li>
              <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>Digital payments, blockchain & AI in finance</li>
            </ul>
          </div>
          <div class="work-card bg-white rounded-2xl p-6">
            <p class="text-xs text-navy-400 mb-2" style="font-family: var(--font-display)">15 Sessions</p>
            <h3 class="font-semibold text-base text-navy-900 mb-3" style="font-family: var(--font-display)">Advanced Financial Management</h3>
            <ul class="space-y-1.5">
              <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>Risk management & hedging</li>
              <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>Advanced analytics & reporting</li>
            </ul>
          </div>
        </div>
        <div class="mt-8">
          <p class="text-xs text-navy-400 font-semibold tracking-widest uppercase mb-4" style="font-family: var(--font-display)">Session Samples</p>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <a href="https://vimeo.com/1175592384" target="_blank" class="group relative block rounded-xl overflow-hidden bg-navy-800 aspect-video">
              <img src="/thumbnails/finance-thumb.jpg" alt="Time Value of Money" class="w-full h-full object-cover opacity-80 group-hover:opacity-60 transition-opacity duration-300" />
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-10 h-10 rounded-full flex items-center justify-center group-hover:bg-white/30 transition-colors" style="background: rgba(255,255,255,0.2); backdrop-filter: blur(4px)">
                  <svg class="w-4 h-4 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>
              <div class="absolute bottom-0 left-0 right-0 p-2" style="background: linear-gradient(to top, rgba(0,0,0,0.7), transparent)">
                <p class="text-white text-[10px] font-medium leading-tight" style="font-family: var(--font-display)">Time Value of Money</p>
              </div>
            </a>
            <a href="https://vimeo.com/1175592202" target="_blank" class="group relative block rounded-xl overflow-hidden bg-navy-800 aspect-video">
              <img src="/thumbnails/finance-thumb.jpg" alt="Working Capital" class="w-full h-full object-cover opacity-80 group-hover:opacity-60 transition-opacity duration-300" />
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-10 h-10 rounded-full flex items-center justify-center group-hover:bg-white/30 transition-colors" style="background: rgba(255,255,255,0.2); backdrop-filter: blur(4px)">
                  <svg class="w-4 h-4 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
