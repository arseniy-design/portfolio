                </a>
              ))}
            </div>
            {tab.posts.length > 6 && (
              <div class="mt-8 text-center">
                <button onclick={`toggleMore('${key}')`} id={`li-more-${key}`}
                  class="px-6 py-2.5 rounded-full border-2 border-navy-200 text-navy-500 text-sm font-semibold hover:border-navy-400 transition-all"
                  style="font-family:var(--font-display)">
                  Show {tab.posts.length - 6} more
                </button>
              </div>
            )}
          </div>
        ));
      })()}

      <!-- Follow CTA -->
      <div class="mt-12 reveal">
        <a href="https://www.linkedin.com/in/arseniygoldberg" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-semibold text-navy-500 hover:text-orange-500 transition-colors"
          style="font-family: var(--font-display)">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          Follow on LinkedIn for more
        </a>
      </div>
    </div>
  </section>

  <script is:inline>
    const liTabColors = { top: '#0D1B2A', hb: '#F4621F', fin: '#0D9488', ent: '#2563EB', ai: '#7C3AED' };
    function switchLiTab(tab) {
      ['top','hb','fin','ent','ai'].forEach(p => {
        const panel = document.getElementById('li-panel-' + p);
        const btn   = document.getElementById('li-tab-' + p);
        if (p === tab) {
          panel.classList.remove('hidden');
          btn.style.background = liTabColors[p];
          btn.style.color = '#fff';
        } else {
          panel.classList.add('hidden');
          btn.style.background = '#F4F1EC';
          btn.style.color = '#0D1B2A';
        }
      });
    }
    function toggleMore(key) {
      const extras = document.querySelectorAll(`.li-extra[data-panel="${key}"]`);
      const btn    = document.getElementById('li-more-' + key);
      const hidden = extras[0]?.classList.contains('hidden');
      extras.forEach(el => el.classList.toggle('hidden', !hidden));
      btn.textContent = hidden ? 'Show less' : `Show ${extras.length} more`;
    }
  </script>

  <!-- CONTACT -->
  <section id="contact" class="py-28" style="background: #0D1B2A">
    <div class="max-w-2xl mx-auto px-8">
      <div class="text-center mb-14 reveal">
        <div class="flex items-center justify-center gap-3 mb-5">
          <div class="w-8 h-px bg-orange-500"></div>
          <span class="text-orange-500 text-xs font-semibold tracking-[0.2em] uppercase" style="font-family: var(--font-display)">Get In Touch</span>
          <div class="w-8 h-px bg-orange-500"></div>
        </div>
        <h2 class="font-bold text-white leading-tight mb-5" style="font-family: var(--font-display); font-size: clamp(2rem,4vw,3rem)">
          Let's work<br>together.
        </h2>
        <p class="text-base max-w-sm mx-auto leading-relaxed" style="color: rgba(255,255,255,0.4)">
          Tell me what you're building. I'll tell you if I can help.
        </p>
      </div>
      <form id="contact-form" class="reveal reveal-delay-1 space-y-4">
        <!-- Engagement type -->
        <div class="mb-2">
          <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color:rgba(255,255,255,0.35);font-family:var(--font-display)">I'm looking for</p>
          <div class="grid grid-cols-2 gap-2">
            {[
              { val: "Teaching & Course Design", label: "Teaching & Course Design" },
              { val: "Strategy & Consulting",    label: "Strategy & Consulting" },
              { val: "AI Implementation",        label: "AI Implementation" },
              { val: "Something else",           label: "Something else" },
            ].map(opt => (
              <button type="button" onclick={`selectEngagement('${opt.val}', this)`}
                class="engagement-btn text-xs font-semibold px-4 py-3 rounded-xl transition-all text-left"
                style="font-family:var(--font-display);background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.5);border:1px solid rgba(255,255,255,0.1)">
                {opt.label}
              </button>
            ))}
          </div>
          <input type="hidden" name="engagement" id="engagement-input" />
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          <input type="text" name="name" placeholder="Your Name" required
            class="w-full text-white placeholder:text-white/25 rounded-xl px-5 py-4 text-sm focus:outline-none transition-colors"
            style="background: #1E2E42; border: 1px solid rgba(255,255,255,0.08); font-family: var(--font-body)" />
          <input type="email" name="email" placeholder="Your Email" required
            class="w-full text-white placeholder:text-white/25 rounded-xl px-5 py-4 text-sm focus:outline-none transition-colors"
            style="background: #1E2E42; border: 1px solid rgba(255,255,255,0.08); font-family: var(--font-body)" />
        </div>
        <input type="text" name="organization" placeholder="Your organization or company"
          class="w-full text-white placeholder:text-white/25 rounded-xl px-5 py-4 text-sm focus:outline-none transition-colors"
          style="background: #1E2E42; border: 1px solid rgba(255,255,255,0.08); font-family: var(--font-body)" />
        <textarea rows="4" name="message" id="contact-message" placeholder="What's the challenge you're trying to solve?"
          class="w-full text-white placeholder:text-white/25 rounded-xl px-5 py-4 text-sm focus:outline-none transition-colors resize-none"
          style="background: #1E2E42; border: 1px solid rgba(255,255,255,0.08); font-family: var(--font-body)"></textarea>
        <button id="submit-btn" type="submit"
          class="w-full bg-orange-500 hover:bg-orange-600 text-white font-semibold py-4 rounded-xl transition-colors text-sm tracking-wide"
          style="font-family: var(--font-display)">
          Send →
        </button>
        <div id="form-success" class="hidden text-center py-6">
          <p class="text-white font-semibold mb-1" style="font-family: var(--font-display)">Got it.</p>
          <p class="text-sm" style="color: rgba(255,255,255,0.45)">I'll be in touch soon.</p>
        </div>
      </form>
    </div>
  </section>

  <!-- INTRO VIDEO LIGHTBOX -->
  <div id="intro-modal" style="display:none;position:fixed;inset:0;z-index:1000;background:rgba(0,0,0,0.92);backdrop-filter:blur(8px);align-items:center;justify-content:center" onclick="closeIntroVideo(event)">
    <div style="position:relative;width:min(900px,92vw);aspect-ratio:16/9;border-radius:16px;overflow:hidden;box-shadow:0 40px 100px rgba(0,0,0,0.6)">
      <iframe id="intro-iframe"
        src=""
        style="width:100%;height:100%;display:block;border:none"
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen>
      </iframe>
    </div>
    <button onclick="closeIntroVideo()" style="position:absolute;top:20px;right:24px;background:rgba(255,255,255,0.1);border:none;color:#fff;font-size:1.4rem;width:40px;height:40px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(4px)">✕</button>
  </div>

  <!-- FOOTER -->
  <footer class="border-t py-8" style="background: #0D1B2A; border-color: rgba(255,255,255,0.05)">
    <div class="max-w-6xl mx-auto px-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <span class="text-sm" style="font-family: var(--font-display); color: rgba(255,255,255,0.25)">© 2025 Arseniy Goldberg</span>
      <div class="flex items-center gap-6">
        <a href="https://www.linkedin.com/in/arseniygoldberg/" target="_blank" class="text-xs uppercase tracking-wide transition-colors hover:text-white/60" style="font-family: var(--font-display); color: rgba(255,255,255,0.3)">LinkedIn</a>
        <a href="https://udsskdlk.gensparkspace.com/" target="_blank" class="text-xs uppercase tracking-wide transition-colors hover:text-white/60" style="font-family: var(--font-display); color: rgba(255,255,255,0.3)">Flow</a>
        <a href="https://findyournorth.net/" target="_blank" class="text-xs uppercase tracking-wide transition-colors hover:text-white/60" style="font-family: var(--font-display); color: rgba(255,255,255,0.3)">North</a>
        <a href="#" class="text-xs uppercase tracking-wide" style="font-family: var(--font-display); color: rgba(255,255,255,0.3)">Stride</a>
      </div>
    </div>
  </footer>

</Layout>

<script>
  // Scroll reveal
  const revealEls = document.querySelectorAll('.reveal');
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('visible'); });
  }, { threshold: 0.08 });
  revealEls.forEach(el => revealObserver.observe(el));

  // Counter animation
  const counters = document.querySelectorAll('.counter');
  const counterObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const target = parseInt(el.dataset.target || '0');
      const steps = 40;
      const increment = target / steps;
      let current = 0;
      const timer = setInterval(() => {
        current += increment;
        if (current >= target) { el.textContent = String(target); clearInterval(timer); }
        else { el.textContent = String(Math.floor(current)); }
      }, 1000 / steps);
      counterObserver.unobserve(el);
    });
  }, { threshold: 0.5 });
  counters.forEach(c => counterObserver.observe(c));

  // Tab switching
  function switchTab(tab: string) {
    document.querySelectorAll('.tab-panel').forEach(el => el.classList.add('hidden'));
    document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
    const panel = document.getElementById('tab-' + tab);
    if (panel) { panel.classList.remove('hidden'); panel.classList.add('tab-panel'); }
    document.querySelector(`[data-tab="${tab}"]`)?.classList.add('active');
  }
  (window as any).switchTab = switchTab;

  // Award panel toggle
  (window as any).selectEngagement = function(val: string, btn: HTMLElement) {
    (document.getElementById('engagement-input') as HTMLInputElement).value = val;
    document.querySelectorAll('.engagement-btn').forEach((b: Element) => {
      (b as HTMLElement).style.background = 'rgba(255,255,255,0.06)';
      (b as HTMLElement).style.color = 'rgba(255,255,255,0.5)';
      (b as HTMLElement).style.borderColor = 'rgba(255,255,255,0.1)';
    });
    btn.style.background = 'rgba(244,98,31,0.15)';
    btn.style.color = '#F4621F';
    btn.style.borderColor = 'rgba(244,98,31,0.4)';
  };

  (window as any).toggleAward = function(year: string) {
    const panel = document.getElementById('award-panel-' + year);
    const btn = document.getElementById('award-btn-' + year);
    if (!panel || !btn) return;
    const isOpen = panel.style.display !== 'none';
    panel.style.display = isOpen ? 'none' : 'block';
    btn.textContent = isOpen ? 'View Awards' : 'Hide Awards';
  };

  // Capital Markets Journey accordion
  (window as any).toggleJourney = function(id: string) {
    const panel = document.getElementById(id);
    const idx = id.replace('cm-', '');
    const arrow = document.getElementById('cm-arrow-' + idx);
    if (!panel) return;
    const isOpen = panel.style.display !== 'none';
    panel.style.display = isOpen ? 'none' : 'block';
    if (arrow) arrow.style.transform = isOpen ? '' : 'rotate(180deg)';
  };

  // Vimeo phone player
  const vimeoScript = document.createElement('script');
  vimeoScript.src = 'https://player.vimeo.com/api/player.js';
  document.head.appendChild(vimeoScript);

  const vimeoPlayers: Record<string, any> = {};

  (window as any).playVimeoPhone = function(key: string) {
    const iframe = document.getElementById('vimeo-' + key) as HTMLIFrameElement;
    const overlay = document.getElementById('overlay-' + key) as HTMLElement;
    const controls = document.getElementById('controls-' + key) as HTMLElement;
    if (!iframe || !overlay) return;
    overlay.style.display = 'none';
    const tryPlay = () => {
      if ((window as any).Vimeo) {
        const player = new (window as any).Vimeo.Player(iframe);
        vimeoPlayers[key] = player;
        player.play();
        if (controls) controls.style.display = 'flex';
      } else {
        setTimeout(tryPlay, 100);
      }
    };
    tryPlay();
  };

  (window as any).seekVimeo = function(key: string, seconds: number) {
    const player = vimeoPlayers[key];
    if (!player) return;
    player.getCurrentTime().then((t: number) => {
      player.setCurrentTime(Math.max(0, t + seconds));
    });
  };

  (window as any).toggleVimeo = function(key: string) {
    const player = vimeoPlayers[key];
    const btn = document.getElementById('playpause-' + key);
    if (!player || !btn) return;
    player.getPaused().then((paused: boolean) => {
      if (paused) {
        player.play();
        btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>';
      } else {
        player.pause();
        btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>';
      }
    });
  };

  // AI walkthrough videos (inline, native controls)
  (window as any).playAiVideo = function(key: string, vid: string) {
    const frame = document.getElementById('aivid-frame-' + key) as HTMLElement;
    if (!frame) return;
    // Replace entire card contents with iframe
    frame.onclick = null;
    frame.style.cursor = 'default';
    frame.innerHTML = `<iframe src="https://player.vimeo.com/video/${vid}?autoplay=1&title=0&byline=0&portrait=0&dnt=1" style="position:absolute;inset:0;width:100%;height:100%;border:none" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>`;
  };

  // Intro video lightbox
  (window as any).openIntroVideo = function() {
    const modal = document.getElementById('intro-modal') as HTMLElement;
    const iframe = document.getElementById('intro-iframe') as HTMLIFrameElement;
    if (!modal || !iframe) return;
    iframe.src = 'https://player.vimeo.com/video/1138054609?autoplay=1&title=0&byline=0&portrait=0&dnt=1';
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  };
  (window as any).closeIntroVideo = function(e?: MouseEvent) {
    if (e && (e.target as HTMLElement).closest('iframe')) return;
    const modal = document.getElementById('intro-modal') as HTMLElement;
    const iframe = document.getElementById('intro-iframe') as HTMLIFrameElement;
    if (!modal) return;
    modal.style.display = 'none';
    if (iframe) iframe.src = '';
    document.body.style.overflow = '';
  };
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') (window as any).closeIntroVideo();
  });

  // Nav scroll effect
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => { navbar?.classList.toggle('scrolled', window.scrollY > 60); }, { passive: true });

  // Mobile menu
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  mobileBtn?.addEventListener('click', () => mobileMenu?.classList.toggle('hidden'));
  mobileMenu?.querySelectorAll('a').forEach(link => link.addEventListener('click', () => mobileMenu.classList.add('hidden')));

  // Testimonial carousel
  (function() {
    const track = document.getElementById('carousel-track');
    const dotsContainer = document.getElementById('carousel-dots');
    if (!track || !dotsContainer) return;
    const slides = track.children;
    const total = slides.length;
    let current = 0;
    let perView = 3;
    let autoTimer: ReturnType<typeof setInterval>;

    function getPerView() {
      if (window.innerWidth < 768) return 1;
      if (window.innerWidth < 1024) return 2;
      return 3;
    }
    function buildDots() {
      dotsContainer.innerHTML = '';
      const pages = Math.ceil(total / perView);
      for (let i = 0; i < pages; i++) {
        const d = document.createElement('button');
        d.className = 'w-2 h-2 rounded-full transition-colors ' + (i === 0 ? 'bg-orange-500' : 'bg-warm-200');
        d.onclick = () => goTo(i * perView);
        dotsContainer.appendChild(d);
      }
    }
    function updateDots() {
      const dots = dotsContainer.querySelectorAll('button');
      const page = Math.floor(current / perView);
      dots.forEach((d, i) => { d.className = 'w-2 h-2 rounded-full transition-colors ' + (i === page ? 'bg-orange-500' : 'bg-warm-200'); });
    }
    function goTo(index: number) {
      perView = getPerView();
      const max = total - perView;
      current = Math.max(0, Math.min(index, max));
      const pct = (100 / perView) * current;
      (track as HTMLElement).style.transform = `translateX(-${pct}%)`;
      Array.from(slides).forEach(s => { (s as HTMLElement).style.minWidth = (100 / perView) + '%'; });
      updateDots();
    }
    (window as any).carouselNext = () => { clearInterval(autoTimer); goTo(current + 1 < total - perView + 1 ? current + 1 : 0); autoTimer = setInterval((window as any).carouselNext, 5000); };
    (window as any).carouselPrev = () => { clearInterval(autoTimer); goTo(current > 0 ? current - 1 : total - perView); autoTimer = setInterval((window as any).carouselNext, 5000); };
    window.addEventListener('resize', () => { perView = getPerView(); buildDots(); goTo(0); });
    perView = getPerView(); buildDots(); goTo(0);
    autoTimer = setInterval((window as any).carouselNext, 5000);
  })();

  // Contact form — AJAX, stays on page
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const formSuccess = document.getElementById('form-success');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.textContent = 'Sending...';
    submitBtn.disabled = true;
    try {
      const res = await fetch('https://formspree.io/f/mgonnqob', {
        method: 'POST',
        headers: { 'Accept': 'application/json' },
        body: new FormData(form)
      });
      if (res.ok) {
        form.querySelectorAll('input, textarea, button').forEach(el => (el as HTMLElement).style.display = 'none');
        formSuccess?.classList.remove('hidden');
      } else {
        submitBtn.textContent = 'Send Message →';
        submitBtn.disabled = false;
      }
    } catch {
      submitBtn.textContent = 'Send Message →';
      submitBtn.disabled = false;
    }
  });
</script>
