---
import Layout from '../layouts/Layout.astro';
---
<Layout>

  <!-- NAV -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 py-5 px-8">
    <div class="max-w-6xl mx-auto flex items-center justify-between">
      <a href="#" class="font-display font-bold text-white text-xl tracking-tight" style="font-family: var(--font-display)">AG</a>
      <div class="hidden md:flex items-center gap-8">
        <a href="#work"        class="text-white/60 hover:text-white text-sm font-medium transition-colors" style="font-family: var(--font-display)">Work</a>
        <a href="#clients"     class="text-white/60 hover:text-white text-sm font-medium transition-colors" style="font-family: var(--font-display)">Clients</a>
        <a href="#brands"      class="text-white/60 hover:text-white text-sm font-medium transition-colors" style="font-family: var(--font-display)">Brands</a>
        <a href="#recognition" class="text-white/60 hover:text-white text-sm font-medium transition-colors" style="font-family: var(--font-display)">Recognition</a>
        <a href="#contact" class="bg-orange-500 hover:bg-orange-600 text-white text-sm font-semibold px-5 py-2.5 rounded-full transition-colors" style="font-family: var(--font-display)">
          Let's Talk
        </a>
      </div>
      <button id="mobile-menu-btn" class="md:hidden text-white/60 hover:text-white">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 right-0 bg-navy-950/95 backdrop-blur-lg border-t border-white/10 px-8 py-6 flex flex-col gap-5">
      <a href="#work"        class="text-white/70 hover:text-white text-sm font-medium transition-colors" style="font-family: var(--font-display)">Work</a>
      <a href="#clients"     class="text-white/70 hover:text-white text-sm font-medium transition-colors" style="font-family: var(--font-display)">Clients</a>
      <a href="#brands"      class="text-white/70 hover:text-white text-sm font-medium transition-colors" style="font-family: var(--font-display)">Brands</a>
      <a href="#recognition" class="text-white/70 hover:text-white text-sm font-medium transition-colors" style="font-family: var(--font-display)">Recognition</a>
      <a href="#contact" class="bg-orange-500 text-white text-sm font-semibold px-5 py-3 rounded-full text-center transition-colors" style="font-family: var(--font-display)">Let's Talk</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero-bg min-h-screen flex items-center overflow-hidden">
    <div class="absolute left-[8%] top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-orange-500/15 to-transparent hidden lg:block"></div>
    <div class="relative z-10 w-full max-w-6xl mx-auto px-8 pt-28 pb-24 grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <h1 class="text-white leading-[1.0] mb-7" style="font-family: var(--font-display)">
          <span class="block font-bold tracking-tight" style="font-size: clamp(2.8rem,6vw,4.5rem)">12 Years.</span>
          <span class="block font-bold tracking-tight" style="font-size: clamp(2.8rem,6vw,4.5rem)">5 Continents.</span>
          <span class="block font-light mt-3" style="font-size: clamp(1.8rem,4vw,2.8rem); color: rgba(255,255,255,0.45)">One Obsession.</span>
        </h1>
        <p class="text-base leading-relaxed max-w-[400px] mb-4" style="color: rgba(255,255,255,0.5)">
          How humans grow — through <em class="not-italic" style="color: rgba(255,255,255,0.85)">Finance</em>,
          <em class="not-italic" style="color: rgba(255,255,255,0.85)">Entrepreneurship</em>, and
          <em class="not-italic" style="color: rgba(255,255,255,0.85)">Artificial Intelligence</em>.
        </p>
        <p class="text-sm mb-10 tracking-widest uppercase" style="font-family: var(--font-display); color: rgba(255,255,255,0.3)">
          I study it &nbsp;·&nbsp; I teach it &nbsp;·&nbsp; I build with it
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="#contact" class="bg-orange-500 hover:bg-orange-600 text-white font-semibold px-8 py-4 rounded-full transition-colors text-sm tracking-wide" style="font-family: var(--font-display)">
            Let's Work Together
          </a>
          <a href="#work" class="text-sm px-8 py-4 rounded-full transition-colors" style="font-family: var(--font-display); border: 1px solid rgba(255,255,255,0.15); color: rgba(255,255,255,0.6)">
            Explore Work ↓
          </a>
        </div>
      </div>
      <div class="relative hidden lg:flex justify-end">
        <div class="relative rounded-2xl overflow-hidden" style="width: 380px; aspect-ratio: 3/4; background: #162236">
          <img src="/hero.jpg" alt="Arseniy Goldberg" class="w-full h-full object-cover object-center" />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(13,27,42,0.5) 0%, transparent 60%)"></div>
        </div>
        <div class="absolute -bottom-3 -left-8 bg-white rounded-2xl px-5 py-4 shadow-2xl flex items-center gap-4">
          <div class="w-10 h-10 bg-orange-500 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
            </svg>
          </div>
          <div>
            <p class="font-bold text-sm leading-tight text-navy-900" style="font-family: var(--font-display)">5× Teaching Excellence</p>
            <p class="text-xs mt-0.5 text-navy-400" style="font-family: var(--font-display)">IE University · 2024 & 2025</p>
          </div>
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-28 pointer-events-none" style="background: linear-gradient(to top, #FAFAF8, transparent)"></div>
  </section>

  <!-- STATS BAR -->
  <section class="bg-warm-50 py-16 border-b border-warm-200">
    <div class="max-w-5xl mx-auto px-8">
      <div class="flex flex-wrap justify-center divide-x divide-warm-200">
        <div class="stat-item flex-1 min-w-[120px] text-center px-8 py-4 reveal">
          <p class="font-bold text-[2.5rem] text-navy-900 leading-none" style="font-family: var(--font-display)"><span class="counter" data-target="12">0</span></p>
          <p class="text-navy-400 text-sm mt-2" style="font-family: var(--font-display)">Years Experience</p>
        </div>
        <div class="stat-item flex-1 min-w-[120px] text-center px-8 py-4 reveal reveal-delay-1">
          <p class="font-bold text-[2.5rem] text-navy-900 leading-none" style="font-family: var(--font-display)"><span class="counter" data-target="5">0</span></p>
          <p class="text-navy-400 text-sm mt-2" style="font-family: var(--font-display)">Continents</p>
        </div>
        <div class="stat-item flex-1 min-w-[120px] text-center px-8 py-4 reveal reveal-delay-2">
          <p class="font-bold text-[2.5rem] text-navy-900 leading-none" style="font-family: var(--font-display)"><span class="counter" data-target="30">0</span><span class="text-orange-500">+</span></p>
          <p class="text-navy-400 text-sm mt-2" style="font-family: var(--font-display)">Institutions</p>
        </div>
        <div class="stat-item flex-1 min-w-[120px] text-center px-8 py-4 reveal reveal-delay-3">
          <p class="font-bold text-[2.5rem] text-navy-900 leading-none" style="font-family: var(--font-display)"><span class="counter" data-target="15">0</span><span class="text-orange-500">+</span></p>
          <p class="text-navy-400 text-sm mt-2" style="font-family: var(--font-display)">Courses Built</p>
        </div>
        <div class="stat-item flex-1 min-w-[120px] text-center px-8 py-4 reveal reveal-delay-4">
          <p class="font-bold text-[2.5rem] text-navy-900 leading-none" style="font-family: var(--font-display)"><span class="counter" data-target="4">0</span></p>
          <p class="text-navy-400 text-sm mt-2" style="font-family: var(--font-display)">Startups</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WORK -->
  <section id="work" class="py-24 bg-warm-100">
    <div class="max-w-6xl mx-auto px-8">

      <div class="mb-16 reveal">
        <div class="section-label">
          <span class="text-orange-500 text-xs font-semibold tracking-[0.2em] uppercase" style="font-family: var(--font-display)">What I Deliver</span>
        </div>
        <h2 class="font-bold text-navy-900 leading-tight" style="font-family: var(--font-display); font-size: clamp(2rem,4vw,3rem)">
          Not just education.<br>
          <span class="text-navy-400 font-light">A full transformation journey.</span>
        </h2>
        <p class="text-navy-400 text-base mt-4 max-w-2xl leading-relaxed">
          Whether you're a company looking to upskill your teams, an L&D leader building executive programs, or an academic institution designing curriculum — the engagement is built around your specific challenge, not a generic syllabus.
        </p>
      </div>

      <!-- Who this is for -->
      <div class="grid md:grid-cols-3 gap-5 mb-16 reveal">
        <div class="bg-white rounded-2xl p-7 border-t-2 border-orange-500">
          <p class="text-orange-500 text-xs font-semibold tracking-widest uppercase mb-3" style="font-family: var(--font-display)">For Organizations</p>
          <h3 class="font-bold text-lg text-navy-900 mb-3" style="font-family: var(--font-display)">Strategic Learning & Implementation</h3>
          <p class="text-navy-400 text-sm leading-relaxed mb-4">You need to change how your teams think, work, or serve clients — and you need it to stick. I design and deliver the full journey from awareness to implementation.</p>
          <ul class="space-y-2">
            <li class="flex items-start gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0 mt-1.5"></span>Finance, AI, and innovation programs</li>
            <li class="flex items-start gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0 mt-1.5"></span>From diagnosis to post-program execution</li>
            <li class="flex items-start gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0 mt-1.5"></span>Measurable behavioral and operational change</li>
          </ul>
        </div>
        <div class="bg-white rounded-2xl p-7 border-t-2 border-navy-300">
          <p class="text-navy-400 text-xs font-semibold tracking-widest uppercase mb-3" style="font-family: var(--font-display)">For L&D Leaders</p>
          <h3 class="font-bold text-lg text-navy-900 mb-3" style="font-family: var(--font-display)">Executive & Professional Training</h3>
          <p class="text-navy-400 text-sm leading-relaxed mb-4">You're building programs for senior professionals who need more than slides. I deliver engaging, high-stakes content with real-world simulations and AI-powered tools.</p>
          <ul class="space-y-2">
            <li class="flex items-start gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-navy-300 flex-shrink-0 mt-1.5"></span>Customized to your sector & audience</li>
            <li class="flex items-start gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-navy-300 flex-shrink-0 mt-1.5"></span>NPS 70 across delivered programs</li>
            <li class="flex items-start gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-navy-300 flex-shrink-0 mt-1.5"></span>Blended: online foundation + live delivery</li>
          </ul>
        </div>
        <div class="bg-white rounded-2xl p-7 border-t-2 border-navy-300">
          <p class="text-navy-400 text-xs font-semibold tracking-widest uppercase mb-3" style="font-family: var(--font-display)">For Academic Institutions</p>
          <h3 class="font-bold text-lg text-navy-900 mb-3" style="font-family: var(--font-display)">Guest Faculty & Curriculum Design</h3>
          <p class="text-navy-400 text-sm leading-relaxed mb-4">You need practitioners who can engage MBA and executive students at the intersection of theory and real-world application — and keep a room alive.</p>
          <ul class="space-y-2">
            <li class="flex items-start gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-navy-300 flex-shrink-0 mt-1.5"></span>5× IE University Teaching Excellence Award</li>
            <li class="flex items-start gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-navy-300 flex-shrink-0 mt-1.5"></span>4.9/5 average participant rating</li>
            <li class="flex items-start gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-navy-300 flex-shrink-0 mt-1.5"></span>Delivered across 30+ global institutions</li>
          </ul>
        </div>
      </div>

      <!-- Results bar -->
      <div class="bg-navy-900 rounded-2xl p-8 mb-16 reveal">
        <p class="text-xs font-semibold tracking-widest uppercase mb-6" style="font-family: var(--font-display); color: rgba(255,255,255,0.4)">Measured Results Across Programs</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          <div class="text-center">
            <p class="font-bold text-3xl text-white mb-1" style="font-family: var(--font-display)">4.9<span class="text-orange-500">/5</span></p>
            <p class="text-xs" style="color: rgba(255,255,255,0.4)">Average participant rating</p>
          </div>
          <div class="text-center">
            <p class="font-bold text-3xl text-white mb-1" style="font-family: var(--font-display)">NPS <span class="text-orange-500">70</span></p>
            <p class="text-xs" style="color: rgba(255,255,255,0.4)">Across delivered programs</p>
          </div>
          <div class="text-center">
            <p class="font-bold text-3xl text-white mb-1" style="font-family: var(--font-display)">5<span class="text-orange-500">hrs</span></p>
            <p class="text-xs" style="color: rgba(255,255,255,0.4)">Saved per week with GenAI</p>
          </div>
          <div class="text-center">
            <p class="font-bold text-3xl text-white mb-1" style="font-family: var(--font-display)">30<span class="text-orange-500">+</span></p>
            <p class="text-xs" style="color: rgba(255,255,255,0.4)">Institutions across 5 continents</p>
          </div>
        </div>
      </div>

      <!-- Curriculum label -->
      <div class="mb-8 reveal">
        <div class="section-label">
          <span class="text-orange-500 text-xs font-semibold tracking-[0.2em] uppercase" style="font-family: var(--font-display)">The Curriculum</span>
        </div>
        <p class="text-navy-400 text-sm">The subject areas I bring to every engagement — customized to your context, not delivered off the shelf.</p>
      </div>

      <!-- Tab bar -->
      <div class="border-b border-warm-200 mb-10 reveal flex overflow-x-auto" id="work-tabs">
        <button class="tab-btn active" data-tab="finance"          onclick="switchTab('finance')">Financial Thinking</button>
        <button class="tab-btn"        data-tab="entrepreneurship" onclick="switchTab('entrepreneurship')">Innovation & Ventures</button>
        <button class="tab-btn"        data-tab="ai"               onclick="switchTab('ai')">AI & Digital Productivity</button>
        <button class="tab-btn"        data-tab="behavioral"       onclick="switchTab('behavioral')">Human Behavior & Decisions</button>
      </div>

      <!-- FINANCE TAB -->
      <div id="tab-finance" class="tab-panel">
        <div class="grid md:grid-cols-3 gap-5">
          <div class="md:col-span-2 work-card work-card-featured bg-white rounded-2xl overflow-hidden">
            <div class="h-40 bg-navy-900 relative flex items-end p-6">
              <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(244,98,31,0.12) 0%, transparent 60%)"></div>
              <span class="relative z-10 bg-orange-500 text-white text-xs font-semibold px-3 py-1.5 rounded-full" style="font-family: var(--font-display)">25 Sessions</span>
            </div>
            <div class="p-7">
              <h3 class="font-bold text-xl text-navy-900 mb-1" style="font-family: var(--font-display)">Capital Markets</h3>
              <p class="text-navy-400 text-sm mb-3">How institutional money moves through global systems — and how to raise, deploy, and protect it.</p>
              <p class="text-orange-500 text-xs font-semibold uppercase tracking-wide mb-3" style="font-family: var(--font-display)">Outcome — Participants leave able to read, navigate, and engage with global capital markets with confidence.</p>
              <ul class="space-y-1.5">
                <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>Equity & debt market structure</li>
                <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>Institutional investors & capital raising</li>
                <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>IPOs, bonds, and alternative financing</li>
                <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>Valuation methods & market dynamics</li>
              </ul>
            </div>
          </div>
          <div class="flex flex-col gap-5">
            <div class="work-card bg-white rounded-2xl p-6 flex-1">
              <p class="text-xs text-navy-400 mb-2" style="font-family: var(--font-display)">15 Sessions</p>
              <h3 class="font-semibold text-base text-navy-900 mb-3" style="font-family: var(--font-display)">Corporate Finance</h3>
              <ul class="space-y-1.5">
                <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>Capital structure & WACC</li>
                <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>Investment decisions & NPV</li>
                <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>Financial strategy & planning</li>
              </ul>
            </div>
            <div class="work-card bg-white rounded-2xl p-6 flex-1">
              <p class="text-xs text-navy-400 mb-2" style="font-family: var(--font-display)">15 Sessions</p>
              <h3 class="font-semibold text-base text-navy-900 mb-3" style="font-family: var(--font-display)">Financial Consulting</h3>
              <ul class="space-y-1.5">
                <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>Advisory skills & client management</li>
                <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>Strategic financial solutions</li>
                <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>CFO-as-a-service frameworks</li>
              </ul>
            </div>
          </div>
          <div class="work-card bg-white rounded-2xl p-6">
            <p class="text-xs text-navy-400 mb-2" style="font-family: var(--font-display)">9 Sessions</p>
            <h3 class="font-semibold text-base text-navy-900 mb-3" style="font-family: var(--font-display)">Business Case Modeling</h3>
            <ul class="space-y-1.5">
              <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>Financial model construction</li>
              <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>Scenario & sensitivity analysis</li>
            </ul>
          </div>
          <div class="work-card bg-white rounded-2xl p-6">
            <p class="text-xs text-navy-400 mb-2" style="font-family: var(--font-display)">15 Sessions</p>
            <h3 class="font-semibold text-base text-navy-900 mb-3" style="font-family: var(--font-display)">Fintech</h3>
            <ul class="space-y-1.5">
              <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>Digital payments & blockchain</li>
              <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>AI in financial services</li>
            </ul>
          </div>
          <div class="work-card bg-white rounded-2xl p-6">
            <p class="text-xs text-navy-400 mb-2" style="font-family: var(--font-display)">15 Sessions</p>
            <h3 class="font-semibold text-base text-navy-900 mb-3" style="font-family: var(--font-display)">Advanced Financial Management</h3>
            <ul class="space-y-1.5">
              <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>Risk management & hedging</li>
              <li class="flex items-center gap-2 text-xs text-navy-500"><span class="w-1 h-1 rounded-full bg-orange-500 flex-shrink-0"></span>Advanced analytics & reporting</li>
            </ul>
          </div>
        </div>
        <div class="mt-8">
          <p class="text-xs text-navy-400 font-semibold tracking-widest uppercase mb-4" style="font-family: var(--font-display)">Session Samples</p>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <a href="https://drive.google.com/file/d/1jQdcKAY7RqyHw2dZz9NbM4CE9NrpsxK-/view" target="_blank" class="group relative block rounded-xl overflow-hidden bg-navy-800 aspect-video">
              <img src="https://drive.google.com/thumbnail?id=1jQdcKAY7RqyHw2dZz9NbM4CE9NrpsxK-&sz=w500" alt="Time Value of Money" class="w-full h-full object-cover opacity-80 group-hover:opacity-60 transition-opacity duration-300" />
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-10 h-10 rounded-full flex items-center justify-center group-hover:bg-white/30 transition-colors" style="background: rgba(255,255,255,0.2); backdrop-filter: blur(4px)">
                  <svg class="w-4 h-4 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>
              <div class="absolute bottom-0 left-0 right-0 p-2" style="background: linear-gradient(to top, rgba(0,0,0,0.7), transparent)">
                <p class="text-white text-[10px] font-medium leading-tight" style="font-family: var(--font-display)">Time Value of Money</p>
