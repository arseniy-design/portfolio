---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Arseniy Goldberg — Finance · Entrepreneurship · AI",
  description = "Portfolio of Arseniy Goldberg — 12 years across Finance, Entrepreneurship, and AI. Educator, consultant, and founder of Flow, North, and Stride."
} = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://api.fontshare.com" />
    <link href="https://api.fontshare.com/v2/css?f[]=clash-display@400,500,600,700&f[]=satoshi@300,400,500,700&display=swap" rel="stylesheet" />

    <!-- Microsoft Clarity — replace CLARITY_PROJECT_ID with your ID from clarity.microsoft.com -->
    <script type="text/javascript">
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window,document,"clarity","script","CLARITY_PROJECT_ID");
    </script>
  </head>
  <body class="bg-warm-50">
    <slot />
    <!-- Vercel Analytics — tracks page views, countries, devices, referrers -->
    <script defer src="/_vercel/insights/script.js"></script>
  </body>
</html>
