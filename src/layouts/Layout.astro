---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Arseniy Goldberg — Finance · Entrepreneurship · AI",
  description = "Portfolio of Arseniy Goldberg — 12 years across Finance, Entrepreneurship, and AI. Educator, consultant, and founder of Flow, North, and Stride."
} = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://api.fontshare.com" />
    <link href="https://api.fontshare.com/v2/css?f[]=clash-display@400,500,600,700&f[]=satoshi@300,400,500,700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-warm-50">
    <slot />
  </body>
</html>
